# Logging level: trace|debug|info|warn|error
MICRO_LOG_LEVEL=info

MICRO_REGISTRY=consul
MICRO_REGISTRY_ADDRESS=127.0.0.1:8500

MICRO_BROKER=rabbitmq
MICRO_BROKER_ADDRESS=amqp://user:pass@127.0.0.1:5672

WEBITEL_DBO_ADDRESS=postgres://user:pass@127.0.0.1:5432/webitel?sslmode=disable&connect_timeout=5
#WEBITEL_DBO_MAX_OPEN_CONNS=25
#WEBITEL_DBO_MAX_IDLE_CONNS=25
#WEBITEL_DBO_CONN_MAX_IDLE_TIME=1m
#WEBITEL_DBO_CONN_MAX_LIFETIME=5m

# gRPC service listen address (host:port; :0 = random port)
MICRO_SERVICE_ADDRESS=127.0.0.1:0
